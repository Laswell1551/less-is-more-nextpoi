# Raw data (~1.1 GB) -- redownloadable via download_data.py; processed splits ARE committed
data/raw/

# Regenerable figures. Every figure in the paper rebuilds from the committed CSV/JSON artifacts:
#   fig_discovery.py     -> figs_v2/fig_discovery.pdf, fig_score.pdf
#   paper_figures_v2.py  -> figs_v2/fig_cutoff|stream|ordering|revisit.pdf
#   fig_llmscale.py      -> figs_v2/fig_llmscale.pdf
figs/
figs_paper/
figs_v2/

# Model weights. The LoRA adapter trained on T0 is 154 MB; REPRODUCE.md gives the command that
# retrains it. The 7B base model lives outside this tree entirely (see llm_audit.py).
models/
lora_t0_nyc/

# LLM *training* prompts (30 MB) -- regenerated deterministically by llm_prep.py.
# The *evaluation* prompts and the model's raw per-candidate scores ARE committed, because they
# are what let a reader re-run llm_alpha_sweep.py and tiebreak_control.py with NO GPU at all.
llm_train_*.jsonl

# Run logs and stderr dumps
*.log
*.err

# Python / OS / editor cruft
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.DS_Store

# LaTeX build artifacts (if the paper sources sit alongside)
*.aux
*.bbl
*.blg
*.out
*.synctex.gz

# Editor / IDE
.vscode/
.idea/
*.swp

# Temp / scratch / our own before-and-after backups
*.tmp
*.tmp.*
*.PREFIX.*
*.F32.*
*.orig
